# LegacyMind AI - Production Environment Configuration
# This file contains production environment variables
# ALL values MUST be stored in secure secret management systems
# NEVER commit actual production credentials

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
ENVIRONMENT=production

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API Configuration
NEXT_PUBLIC_API_URL=https://api.legacymind.ai
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false

# UI Configuration
NEXT_PUBLIC_APP_NAME=LegacyMind AI
NEXT_PUBLIC_APP_VERSION=${APP_VERSION}

# ============================================
# BACKEND CONFIGURATION
# ============================================
# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=WARNING

# Database Configuration
DATABASE_URL=${PRODUCTION_DATABASE_URL}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_SSL_MODE=require
DATABASE_SSL_CERT=${PRODUCTION_DB_SSL_CERT}

# Redis Configuration
REDIS_URL=${PRODUCTION_REDIS_URL}
REDIS_MAX_CONNECTIONS=50
REDIS_SSL=true
REDIS_PASSWORD=${PRODUCTION_REDIS_PASSWORD}

# ============================================
# AI/ML SERVICES
# ============================================
# OpenAI Configuration
OPENAI_API_KEY=${PRODUCTION_OPENAI_API_KEY}
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_RATE_LIMIT=100
OPENAI_ORGANIZATION=${PRODUCTION_OPENAI_ORG}

# IBM Watson Configuration
IBM_WATSON_API_KEY=${PRODUCTION_IBM_WATSON_API_KEY}
IBM_WATSON_URL=${PRODUCTION_IBM_WATSON_URL}

# Hugging Face Configuration
HUGGINGFACE_API_KEY=${PRODUCTION_HUGGINGFACE_API_KEY}

# ============================================
# VECTOR DATABASE
# ============================================
# Pinecone Configuration
PINECONE_API_KEY=${PRODUCTION_PINECONE_API_KEY}
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=legacymind-production

# ChromaDB Configuration
CHROMA_HOST=${PRODUCTION_CHROMA_HOST}
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=legacymind_embeddings_production
CHROMA_AUTH_TOKEN=${PRODUCTION_CHROMA_AUTH_TOKEN}

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Configuration
JWT_SECRET_KEY=${PRODUCTION_JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# API Keys
API_KEY_HEADER=X-API-Key
INTERNAL_API_KEY=${PRODUCTION_INTERNAL_API_KEY}

# CORS Configuration
CORS_ORIGINS=https://legacymind.ai,https://www.legacymind.ai
CORS_ALLOW_CREDENTIALS=true

# Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ============================================
# FILE STORAGE
# ============================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=${PRODUCTION_AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${PRODUCTION_AWS_SECRET_ACCESS_KEY}
AWS_REGION=us-east-1
AWS_S3_BUCKET=legacymind-production
AWS_S3_ENCRYPTION=AES256
AWS_S3_VERSIONING=true

# Upload Configuration
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=.py,.js,.ts,.java,.cpp,.c,.go,.rb,.php,.cs

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry Configuration
SENTRY_DSN=${PRODUCTION_SENTRY_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=${PRODUCTION_APPINSIGHTS_KEY}

# CloudWatch
AWS_CLOUDWATCH_LOG_GROUP=/legacymind/production
AWS_CLOUDWATCH_LOG_STREAM=application
AWS_CLOUDWATCH_RETENTION_DAYS=90

# Datadog (if using)
DATADOG_API_KEY=${PRODUCTION_DATADOG_API_KEY}
DATADOG_APP_KEY=${PRODUCTION_DATADOG_APP_KEY}
DATADOG_SITE=datadoghq.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=3000
RATE_LIMIT_PER_DAY=50000

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_ENABLED=true
CACHE_TTL=7200  # 2 hours
CACHE_MAX_SIZE=50000

# ============================================
# EXTERNAL SERVICES
# ============================================
# GitHub Integration
GITHUB_CLIENT_ID=${PRODUCTION_GITHUB_CLIENT_ID}
GITHUB_CLIENT_SECRET=${PRODUCTION_GITHUB_CLIENT_SECRET}
GITHUB_WEBHOOK_SECRET=${PRODUCTION_GITHUB_WEBHOOK_SECRET}
GITHUB_APP_ID=${PRODUCTION_GITHUB_APP_ID}
GITHUB_PRIVATE_KEY=${PRODUCTION_GITHUB_PRIVATE_KEY}

# Email Service
SMTP_HOST=${PRODUCTION_SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${PRODUCTION_SMTP_USER}
SMTP_PASSWORD=${PRODUCTION_SMTP_PASSWORD}
SMTP_FROM_EMAIL=noreply@legacymind.ai
SMTP_FROM_NAME=LegacyMind AI
SMTP_USE_TLS=true

# SendGrid (alternative)
SENDGRID_API_KEY=${PRODUCTION_SENDGRID_API_KEY}

# ============================================
# CDN & ASSETS
# ============================================
CDN_URL=https://cdn.legacymind.ai
STATIC_ASSETS_URL=https://assets.legacymind.ai
CDN_CACHE_CONTROL=public, max-age=31536000, immutable

# ============================================
# PERFORMANCE
# ============================================
# Connection Pooling
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT=30

# Request Timeout
REQUEST_TIMEOUT=30
SLOW_REQUEST_THRESHOLD=5

# Worker Configuration
WORKER_PROCESSES=8
WORKER_THREADS=4
WORKER_MAX_REQUESTS=10000
WORKER_MAX_REQUESTS_JITTER=1000

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=legacymind-backups
BACKUP_ENCRYPTION_KEY=${PRODUCTION_BACKUP_ENCRYPTION_KEY}

# Point-in-Time Recovery
PITR_ENABLED=true
PITR_RETENTION_DAYS=7

# ============================================
# COMPLIANCE & AUDIT
# ============================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
GDPR_COMPLIANCE=true
DATA_RESIDENCY=US

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BETA_FEATURES=false
FEATURE_MAINTENANCE_MODE=false

# ============================================
# SCALING & AUTO-SCALING
# ============================================
AUTO_SCALING_ENABLED=true
MIN_INSTANCES=2
MAX_INSTANCES=10
TARGET_CPU_UTILIZATION=70

# ============================================
# SSL/TLS
# ============================================
SSL_CERT_PATH=${PRODUCTION_SSL_CERT_PATH}
SSL_KEY_PATH=${PRODUCTION_SSL_KEY_PATH}
SSL_CA_BUNDLE_PATH=${PRODUCTION_SSL_CA_BUNDLE_PATH}

# ============================================
# PAYMENT & BILLING (if applicable)
# ============================================
STRIPE_SECRET_KEY=${PRODUCTION_STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${PRODUCTION_STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${PRODUCTION_STRIPE_WEBHOOK_SECRET}

# ============================================
# ANALYTICS
# ============================================
GOOGLE_ANALYTICS_ID=${PRODUCTION_GA_ID}
MIXPANEL_TOKEN=${PRODUCTION_MIXPANEL_TOKEN}

# ============================================
# SECURITY SCANNING
# ============================================
SECURITY_SCAN_ENABLED=true
VULNERABILITY_SCAN_SCHEDULE=0 3 * * *  # Daily at 3 AM

# ============================================
# NOTES
# ============================================
# CRITICAL SECURITY REQUIREMENTS:
# 1. ALL ${VARIABLE} placeholders MUST be replaced with actual secrets
# 2. Store ALL secrets in AWS Secrets Manager, Azure Key Vault, or similar
# 3. NEVER commit actual production credentials to version control
# 4. Rotate ALL secrets every 90 days minimum
# 5. Use different credentials for each environment
# 6. Enable MFA for all service accounts
# 7. Implement least privilege access
# 8. Monitor and audit all secret access
# 9. Have incident response plan for credential leaks
# 10. Regular security audits and penetration testing