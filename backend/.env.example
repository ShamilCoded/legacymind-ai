# LLM Provider Configuration
# Choose 'openai' or 'anthropic'
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Model options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
MODEL_NAME=gpt-4-turbo-preview

# Anthropic Configuration (alternative to OpenAI)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MODEL_NAME=claude-3-opus-20240229

# Embedding Model Configuration
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, all-distilroberta-v1
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store Configuration
VECTOR_STORE_PATH=./vector_store_data
INDEX_TYPE=flat  # Options: flat, ivf, hnsw

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=*  # Comma-separated list or * for all

# Session Configuration
SESSION_STORAGE_DIR=./chat_sessions
MAX_SESSION_MESSAGES=50

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=rag_chatbot.log

# Repository Indexing Configuration
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_FILE_PATTERNS=*.py,*.js,*.ts,*.tsx,*.jsx,*.md,*.txt
DEFAULT_EXCLUDE_PATTERNS=*/node_modules/*,*/.git/*,*/venv/*,*/__pycache__/*

# Search Configuration
DEFAULT_SEARCH_K=5
SCORE_THRESHOLD=0.3

# Performance Configuration
BATCH_SIZE=32
USE_GPU=false  # Set to true if using faiss-gpu

# Made with Bob