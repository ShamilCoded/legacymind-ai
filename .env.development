# LegacyMind AI - Development Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
ENVIRONMENT=development

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false
NEXT_PUBLIC_ENABLE_DEBUG_MODE=true

# UI Configuration
NEXT_PUBLIC_APP_NAME=LegacyMind AI
NEXT_PUBLIC_APP_VERSION=1.0.0-dev

# ============================================
# BACKEND CONFIGURATION
# ============================================
# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# Database Configuration (if needed)
DATABASE_URL=postgresql://localhost:5432/legacymind_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (if needed)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# ============================================
# AI/ML SERVICES
# ============================================
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# IBM Watson Configuration (if applicable)
IBM_WATSON_API_KEY=your_ibm_watson_key_here
IBM_WATSON_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com

# Hugging Face Configuration (if applicable)
HUGGINGFACE_API_KEY=your_huggingface_key_here

# ============================================
# VECTOR DATABASE
# ============================================
# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=legacymind-dev

# ChromaDB Configuration (alternative)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=legacymind_embeddings_dev

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_for_development_only
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys
API_KEY_HEADER=X-API-Key
INTERNAL_API_KEY=dev_internal_api_key_change_in_production

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ============================================
# FILE STORAGE
# ============================================
# Local Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# AWS S3 Configuration (if needed)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=legacymind-dev

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry Configuration
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application Insights (if using Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600  # 1 hour in seconds
CACHE_MAX_SIZE=1000

# ============================================
# EXTERNAL SERVICES
# ============================================
# GitHub Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Email Service (if needed)
SMTP_HOST=localhost
SMTP_PORT=1025  # MailHog for local development
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@legacymind.local

# ============================================
# DEVELOPMENT TOOLS
# ============================================
# Hot Reload
WATCHPACK_POLLING=false

# Source Maps
GENERATE_SOURCEMAP=true

# Profiling
ENABLE_PROFILING=false

# ============================================
# TESTING
# ============================================
TEST_DATABASE_URL=postgresql://localhost:5432/legacymind_test
TEST_REDIS_URL=redis://localhost:6379/1

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Use .env.local for your personal overrides
# 3. Keep sensitive data in a secure vault
# 4. Update .env.example when adding new variables