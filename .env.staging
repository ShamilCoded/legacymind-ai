# LegacyMind AI - Staging Environment Configuration
# This file contains staging environment variables
# Actual values should be stored in GitHub Secrets or your deployment platform

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
ENVIRONMENT=staging

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API Configuration
NEXT_PUBLIC_API_URL=https://api-staging.legacymind.ai
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false

# UI Configuration
NEXT_PUBLIC_APP_NAME=LegacyMind AI (Staging)
NEXT_PUBLIC_APP_VERSION=${APP_VERSION}

# ============================================
# BACKEND CONFIGURATION
# ============================================
# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=${STAGING_DATABASE_URL}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_SSL_MODE=require

# Redis Configuration
REDIS_URL=${STAGING_REDIS_URL}
REDIS_MAX_CONNECTIONS=20
REDIS_SSL=true

# ============================================
# AI/ML SERVICES
# ============================================
# OpenAI Configuration
OPENAI_API_KEY=${STAGING_OPENAI_API_KEY}
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_RATE_LIMIT=50

# IBM Watson Configuration
IBM_WATSON_API_KEY=${STAGING_IBM_WATSON_API_KEY}
IBM_WATSON_URL=${STAGING_IBM_WATSON_URL}

# Hugging Face Configuration
HUGGINGFACE_API_KEY=${STAGING_HUGGINGFACE_API_KEY}

# ============================================
# VECTOR DATABASE
# ============================================
# Pinecone Configuration
PINECONE_API_KEY=${STAGING_PINECONE_API_KEY}
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=legacymind-staging

# ChromaDB Configuration
CHROMA_HOST=${STAGING_CHROMA_HOST}
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=legacymind_embeddings_staging

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Configuration
JWT_SECRET_KEY=${STAGING_JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys
API_KEY_HEADER=X-API-Key
INTERNAL_API_KEY=${STAGING_INTERNAL_API_KEY}

# CORS Configuration
CORS_ORIGINS=https://staging.legacymind.ai
CORS_ALLOW_CREDENTIALS=true

# ============================================
# FILE STORAGE
# ============================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=${STAGING_AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${STAGING_AWS_SECRET_ACCESS_KEY}
AWS_REGION=us-east-1
AWS_S3_BUCKET=legacymind-staging
AWS_S3_ENCRYPTION=AES256

# Upload Configuration
MAX_UPLOAD_SIZE=104857600  # 100MB

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry Configuration
SENTRY_DSN=${STAGING_SENTRY_DSN}
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.5

# Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=${STAGING_APPINSIGHTS_KEY}

# CloudWatch (if using AWS)
AWS_CLOUDWATCH_LOG_GROUP=/legacymind/staging
AWS_CLOUDWATCH_LOG_STREAM=application

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ============================================
# EXTERNAL SERVICES
# ============================================
# GitHub Integration
GITHUB_CLIENT_ID=${STAGING_GITHUB_CLIENT_ID}
GITHUB_CLIENT_SECRET=${STAGING_GITHUB_CLIENT_SECRET}
GITHUB_WEBHOOK_SECRET=${STAGING_GITHUB_WEBHOOK_SECRET}

# Email Service
SMTP_HOST=${STAGING_SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${STAGING_SMTP_USER}
SMTP_PASSWORD=${STAGING_SMTP_PASSWORD}
SMTP_FROM_EMAIL=noreply@staging.legacymind.ai
SMTP_USE_TLS=true

# ============================================
# CDN & ASSETS
# ============================================
CDN_URL=https://cdn-staging.legacymind.ai
STATIC_ASSETS_URL=https://assets-staging.legacymind.ai

# ============================================
# PERFORMANCE
# ============================================
# Connection Pooling
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Request Timeout
REQUEST_TIMEOUT=30

# Worker Configuration
WORKER_PROCESSES=4
WORKER_THREADS=2

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=7

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BETA_FEATURES=true

# ============================================
# NOTES
# ============================================
# 1. All ${VARIABLE} placeholders should be replaced with actual secrets
# 2. Store secrets in GitHub Secrets or your deployment platform's secret manager
# 3. Never commit actual credentials to version control
# 4. Rotate secrets regularly
# 5. Use different credentials for staging and production